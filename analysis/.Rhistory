library(ggplot2)
library(patchwork)
# Create the individual subplots
p1 <- ggplot(data.frame(x = rnorm(100), y = rnorm(100)), aes(x, y)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE) +
labs(title = "Quadrant 1 (EV BV)") +
theme_minimal()
p2 <- ggplot(data.frame(x = rnorm(100, mean = 2), y = rnorm(100, mean = 2)), aes(x, y)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE) +
labs(title = "Quadrant 2 (ET BV)") +
theme_minimal()
p3 <- ggplot(data.frame(x = rnorm(100, mean = -2), y = rnorm(100, mean = -2)), aes(x, y)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE) +
labs(title = "Quadrant 3 (BT EV)") +
theme_minimal()
p4 <- ggplot(data.frame(x = rnorm(100, mean = 0), y = rnorm(100, mean = 0)), aes(x, y)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE) +
labs(title = "Quadrant 4 (BM)") +
theme_minimal()
# Combine the plots
combined_plot <- (p1 + p2) / (p3 + p4) +
plot_layout(guides = 'collect') +
plot_annotation(title = 'Signal vs Predict')
# Display the combined plot
print(combined_plot)
